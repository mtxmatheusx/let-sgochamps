# Supabase configuration.
# Copy this file to `.env` for local dev, and set the same vars in your host
# (Vercel / Cloudflare) dashboard for production builds.
#
# NOTE: production talks to the "LETSGOCHAMPS" Supabase project
# (ref: dystxaxrtyqpccjboucg). The previously committed .env pointed at a
# different, stale ref (ymwldhhgytxpafhtrpnc) — make sure your real values below
# (and in the host dashboard) point at the correct project.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_ANON_PUBLISHABLE_KEY
VITE_SUPABASE_PROJECT_ID=YOUR_PROJECT_REF
